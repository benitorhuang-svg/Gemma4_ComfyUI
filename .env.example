# --- RTX 2060 (6GB) 專屬優化配置 ---
COMFYUI_PORT=8188
OLLAMA_PORT=11434
WEBUI_PORT=8080

# --- 模型設定 (選用最強 2B Uncensored 版) ---
# 推薦版本: 
# - tripolskypetr/gemma4-uncensored-aggressive (2B, 適合 6GB VRAM)
GEMMA_MODEL=tripolskypetr/gemma4-uncensored-aggressive
OLLAMA_IMAGE=ollama/ollama:latest

# --- 外部分享與安全 (Ngrok) ---
# 前往 https://dashboard.ngrok.com/get-started/your-authtoken 獲取
NGROK_TOKEN=your_ngrok_token_here
# 設定存取密碼 (格式 user:password)，若留空則為公開存取
NGROK_AUTH=admin:gemma4_secret_2026

# --- Open WebUI 安全金鑰 ---
WEBUI_SECRET_KEY=gemma4_super_secret_key_change_me

# --- GPU 優化參數 (6GB 專屬) ---
# OLLAMA_FLASH_ATTENTION=1 (預設已開啟)
# OLLAMA_KV_CACHE_TYPE=turbo4 (預設已開啟)
# OLLAMA_KEEP_ALIVE=0s (已在 docker-compose 中強制設定，確保顯存回收)
